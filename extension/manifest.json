{
  "manifest_version": 3,
  "name": "Uyap Flow — Toplu Evrak İndirici",
  "short_name": "Uyap Flow",
  "version": "2.3.7",
  "description": "Uyap Flow: UYAP Avukat Portal için toplu evrak indirici. UDF/PDF, ZIP arşivi, PDF birleştirme, Excel listesi, filtreler, çoklu dosya kuyruğu, seçim modu, PTT tebligat sorgulama ve daha fazlası.",
  "host_permissions": [
    "https://avukat.uyap.gov.tr/*",
    "https://gonderitakip.ptt.gov.tr/*",
    "https://*.ptt.gov.tr/*"
  ],
  "action": {
    "default_title": "Uyap Flow (sayfadaki yüzen butonu)"
  },
  "content_scripts": [
    {
      "matches": ["https://avukat.uyap.gov.tr/*"],
      "js": ["lib/jszip.min.js", "lib/pdf-lib.min.js", "main.js"],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": [
        "https://gonderitakip.ptt.gov.tr/*",
        "https://*.ptt.gov.tr/*"
      ],
      "js": ["ptt-helper.js"],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": false
    }
  ]
}
